{
  "name": "freelanceos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:wrangler": "wrangler pages dev .next/server",
    "build": "next build",
    "pages:build": "npx @cloudflare/next-on-pages@1",
    "pages:dev": "wrangler pages dev .next/server --port 8787",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static --project-name=freelanceos",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.6",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.7",
    "next": "^15.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "wrangler": "^4.76.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.8",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3"
  }
}
